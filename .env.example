# Flask Configuration
SECRET_KEY=your_super_secret_key_here
FLASK_APP=run.py
FLASK_DEBUG=False

# Database Configuration (SQLite by default, or Postgres for production)
SQLALCHEMY_DATABASE_URI=sqlite:///report_it_now.db

# Google Maps API (Required for the location autocomplete)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Email Configuration (For status update notifications)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_specific_password
MAIL_DEFAULT_SENDER=your_email@gmail.com
